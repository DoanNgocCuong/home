# ══════════════════════════════════════════════════════════════
#  LOG ANALYSIS AGENT v2 — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=logagent
POSTGRES_PASSWORD=change_me_in_production

# ── Datadog (nếu muốn pull log từ DD, bỏ trống nếu dùng OTel) ──
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com
DATADOG_CLUSTER=prod-rancher-01

# ── LLM API Keys (cần ít nhất 1) ────────────────────────────
# Tier 2: DeepSeek (rẻ, classify + summarize)
DEEPSEEK_API_KEY=sk-xxx
LLM_TIER2_MODEL=deepseek-chat

# Tier 3: OpenAI (đắt, deep RCA + recommendation)
OPENAI_API_KEY=sk-xxx
LLM_TIER3_MODEL=gpt-4o

# ── Langfuse (tạo key tại http://localhost:3000 sau khi start) ──
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx

# ── Agent Config ─────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300
ANOMALY_THRESHOLD=2.0
USE_SAMPLE_DATA=true

# ── Langfuse Internal ───────────────────────────────────────
LANGFUSE_SECRET=change-this-to-random-string
LANGFUSE_SALT=change-this-to-another-random-string
