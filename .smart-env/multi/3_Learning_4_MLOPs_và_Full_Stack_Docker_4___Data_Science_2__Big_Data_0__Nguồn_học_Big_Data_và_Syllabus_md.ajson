h":0,"last_read":{"hash":"5b52edded8d272ae178ec94efa65db4913e444d446dd575a9e69f82d3df8794a","at":1746453039041},"key":"3_Learning/4_MLOPs và Full Stack Docker/4.. Data Science/2. Big Data/0. Nguồn học Big Data và Syllabus.md#","lines":[1,8],"size":1342,"outlinks":[{"title":"IT4931 - Lưu trữ và xử lý dữ liệu lớn | Viet-Trung Tran","target":"https://datalab.vn/articles/2020-03/it4931-luu-tru-va-xu-ly-du-lieu-lon","line":1},{"title":"trungtv/IT4931_data_management_and_processing_lab_materials: Dữ liệu lớn yêu cầu cần có các cơ chế, kỹ thuật xử lý dữ liệu ở quy mô lớn và hiệu quả. Học phần này nhằm cung cấp cho người học các kiến thức về công nghệ lưu trữ dữ liệu lớn, các hệ quản trị cơ sở dữ liệu NoSQL, NewSQL, các nguyên lý xử lý dữ liệu song song, phân tán, theo khối, theo luồng, xử lý sự kiện phức tạp, quản lý luồng công việc. Bên cạnh đó, người học được làm quen và vận dụng các công nghệ xử lý dữ liệu lớn trên nền tảng Hadoop - Map Reduce, và Spark. Sau khi kết thúc học phần này người học có khả năng hiểu, lựa chọn, cài đặt, và vận hành các giải pháp lưu trữ và xử lý dữ liệu phù hợp dựa trên các kiến thức học được cho các bài toán ứng dụng cụ thể liên quan tới dữ liệu lớn.","target":"https://github.com/trungtv/IT4931_data_management_and_processing_lab_materials","line":2},{"title":"trinodb/trino-the-definitive-guide: Resource for the book Trino: The Definitive Guide (and formerly Presto: The Definitive Guide)","target":"https://github.com/trinodb/trino-the-definitive-guide?tab=readme-ov-file","line":3},{"title":"hub.docker.com/r/trinodb/trino","target":"https://hub.docker.com/r/trinodb/trino","line":4},{"title":"Starburst Galaxy","target":"https://doanngoccuong.galaxy.starburst.io/home","line":5}],"class_name":"SmartBlock"},
