ne":2},{"title":"trinodb/trino-the-definitive-guide: Resource for the book Trino: The Definitive Guide (and formerly Presto: The Definitive Guide)","target":"https://github.com/trinodb/trino-the-definitive-guide?tab=readme-ov-file","line":3},{"title":"hub.docker.com/r/trinodb/trino","target":"https://hub.docker.com/r/trinodb/trino","line":4},{"title":"Starburst Galaxy","target":"https://doanngoccuong.galaxy.starburst.io/home","line":5}],"class_name":"SmartBlock"},
